# Copy to .env and fill in real values from the UVA RC GenAI portal:
# https://open-webui.rc.virginia.edu/  (Settings -> Account -> API keys)

LLM_BASE_URL=https://open-webui.rc.virginia.edu/api
LLM_API_KEY=replace-with-your-rivanna-genai-token
LLM_MODEL=moonshotai/kimi-k2-instruct

# Agent listens on this port — every attack script targets it.
AGENT_PORT=8001

# Path the agent serves notes from (memory-poisoning attack target).
NOTES_DB=./agent/notes.db
