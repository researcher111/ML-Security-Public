# Copy to .env (cp .env.example .env), then fill in your real token.
# Get your API key from the UVA RC GenAI portal:
#   https://open-webui.rc.virginia.edu/  ->  Settings -> Account -> API keys
# Run from a Rivanna session so this endpoint is reachable directly (no tunnel).

LLM_BASE_URL=https://open-webui.rc.virginia.edu/api
LLM_API_KEY=YOUR_API_KEY_HERE
LLM_MODEL=Kimi K2.5
